# Frontend (Vite) environment template
# Copy this file to: site/.env
#
# Used by the React app only.
# Do NOT put secrets here (browser bundles can expose values).
#
# Backend secrets belong in: site/backend/.env

# Backend API base URL used by the frontend
VITE_API_URL=http://localhost:5000/api

# Toggle Flask-backed features in the UI
VITE_FLASK_ENABLED=true

# Optional mobile profile: see .env.mobile